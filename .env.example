# GEMINI_API_KEY: Server-side key for API calls. 
# In AI Studio, this is managed in the Secrets panel.
GEMINI_API_KEY=

# VITE_GEMINI_API_KEY: Client-side key for static deployments (Vercel/Hostinger).
# This is used as a fallback if the backend proxy fails or is unavailable.
VITE_GEMINI_API_KEY=

# VITE_CHATBOT_MODEL: Default model for agents. 
# Use 'gemini-flash-latest' or 'gemini-pro-latest' for auto-updating model-agnostic aliases.
VITE_CHATBOT_MODEL=gemini-flash-latest

# APP_URL: The URL where this applet is hosted.
APP_URL=

# VITE_ENABLE_CMS_INIT: Set to 'true' to show the CMS Initialization tool in the Admin Dashboard.
VITE_ENABLE_CMS_INIT=true
# VITE_AUTO_INIT: Set to 'true' to automatically initialize CMS data if missing (Admin only).
VITE_AUTO_INIT=true

# GOOGLE_CLIENT_ID: Required for Google Calendar OAuth.
GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET: Required for Google Calendar OAuth.
GOOGLE_CLIENT_SECRET=
